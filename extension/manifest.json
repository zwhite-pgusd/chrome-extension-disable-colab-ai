{
  "manifest_version": 3,
  "name": "pgext",
  "version": "1.0.7",
  "description": "Removes generative AI elements from Google Colab. Blocks YouTube embedding in Google Docs and Slides. Suppresses AI UI on Google Search.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://colab.research.google.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://docs.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "https://www.google.com/search*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "update_url": "https://zwhite-pgusd.github.io/chrome-extension-disable-colab-ai/updates.xml",
  "key": ""
}
